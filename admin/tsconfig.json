{
  "compilerOptions": {
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2023",
    "module": "nodenext",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "preserveSymlinks": true,
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["jest", "node"],
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}
