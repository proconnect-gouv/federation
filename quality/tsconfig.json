{
  "compilerOptions": {
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["dom"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "types": ["cypress", "cypress-axe", "node"]
  },
  "include": ["**/*.ts", "*.js"]
}
